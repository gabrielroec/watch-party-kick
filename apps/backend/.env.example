# Porta do servidor HTTP/WebSocket.
PORT=4000

# CORS: origens permitidas (painel em dev + extensao Chrome).
# chrome-extension://<id> a gente adiciona depois que a extensao for instalada.
ALLOWED_ORIGINS=http://localhost:3000

# LiveKit Cloud (free tier) - criar em https://cloud.livekit.io
# Apos criar um projeto, copiar estas 3 infos da aba "Settings > Keys".
LIVEKIT_URL=wss://SEU-PROJETO.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxx
LIVEKIT_API_SECRET=secret-xxxxxxxxxxxxxxxxxxxxxxx
